[configuration]
entry_symbol = "path_mesh_3d_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]
macos.debug = "res://addons/PathMesh3D/bin/libpath_mesh_3d.macos.template_debug.dev.dylib"
macos.release = "res://addons/PathMesh3D/bin/libpath_mesh_3d.macos.template_release.dylib"
windows.debug.x86_64 = "res://addons/PathMesh3D/bin/path_mesh_3d.windows.template_debug.dev.x86_64.dll"
windows.release.x86_64 = "res://addons/PathMesh3D/bin/path_mesh_3d.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/PathMesh3D/bin/libpath_mesh_3d.linux.template_debug.dev.x86_64.so"
linux.release.x86_64 = "res://addons/PathMesh3D/bin/libpath_mesh_3d.linux.template_release.x86_64.so"

[icons]
PathMesh3D = "res://addons/PathMesh3D/icons/PathMesh3D.svg"
PathExtrude3D = "res://addons/PathMesh3D/icons/PathExtrude3D.svg"
PathMultiMesh3D = "res://addons/PathMesh3D/icons/PathMultiMesh3D.svg"
PathScene3D = "res://addons/PathMesh3D/icons/PathScene3D.svg"
PathModifier3D = "res://addons/PathMesh3D/icons/PathModifier3D.svg"
PathStaticBody3D = "res://addons/PathMesh3D/icons/PathStaticBody3D.svg"
PathArea3D = "res://addons/PathMesh3D/icons/PathArea3D.svg"
